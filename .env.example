# Database (PostgreSQL)
# Для локальной разработки:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/familyhub?schema=public"
# Для Neon (продакшн):
# DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL — для миграций через Vercel (непулерное соединение). На локалке = DATABASE_URL
# DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL=""
DIRECT_URL=""

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Сгенерируйте: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production"

# UploadThing (для загрузки фото/видео)
# Зарегистрируйтесь на https://uploadthing.com, создайте приложение
# и скопируйте ключи в Settings → API Keys
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="FamilyHub"

# Web Push (VAPID) — для push-уведомлений на телефон
# Сгенерировать: node -e "const c=require('crypto');const keys=c.generateKeyPairSync('ec',{namedCurve:'P-256',publicKeyEncoding:{type:'spki',format:'der'},privateKeyEncoding:{type:'pkcs8',format:'der'}});console.log('VAPID_PUBLIC_KEY='+Buffer.from(keys.publicKey).toString('base64url'));console.log('VAPID_PRIVATE_KEY='+Buffer.from(keys.privateKey).toString('base64url'))"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
