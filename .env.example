# Database (PostgreSQL)
# Для локальной разработки:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/familyhub?schema=public"
# Для Neon (продакшн):
# DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/familyhub?sslmode=require"
DATABASE_URL=""

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Сгенерируйте: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production"

# UploadThing (для загрузки фото/видео)
# Зарегистрируйтесь на https://uploadthing.com, создайте приложение
# и скопируйте ключи в Settings → API Keys
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="FamilyHub"
