generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  PARENT
  FAMILY_MEMBER
  GUEST
}

enum PostVisibility {
  EVERYONE
  FAMILY_ONLY
  PARENTS_ONLY
}

enum ArchiveCategory {
  PHOTO
  VIDEO
  DOCUMENT
  CERTIFICATE
  HEIRLOOM
}

enum EventType {
  BIRTHDAY
  ANNIVERSARY
  HOLIDAY
  FAMILY_MEETING
  CUSTOM
}

enum PollStatus {
  ACTIVE
  CLOSED
}

model Family {
  id         String   @id @default(cuid())
  name       String   @unique
  inviteCode String   @unique
  createdAt  DateTime @default(now())

  createdBy     String
  members       User[]
  familyMembers FamilyMember[]

  @@map("families")
}

model User {
  id            String   @id @default(cuid())
  email             String      @unique
  emailVerified     Boolean     @default(false)
  verificationToken String?
  name              String?
  passwordHash      String?
  image             String?
  role              Role        @default(FAMILY_MEMBER)
  bio           String?
  phone         String?
  dateOfBirth   DateTime?
  familyId      String?
  family        Family?  @relation(fields: [familyId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  posts         Post[]
  comments      Comment[]
  likes         Like[]
  messagesSent      Message[]  @relation("SentMessages")
  messagesReceived  Message[]  @relation("ChatMessages")
  chatMemberships   ChatRoomMember[]
  notifications      Notification[]
  pushSubscriptions  PushSubscription[]
  pollVotes          PollVote[]
  events        Event[]
  archiveItems  ArchiveItem[]
  memories      Memory[]
  polls         Poll[]
  activityLogs  ActivityLog[]
  pets          Pet[]

  @@index([familyId])
  @@map("users")
}

model Post {
  id         String          @id @default(cuid())
  content    String
  image      String?
  images     String[] @default([])
  video      String?
  document   String?
  tags       String[]
  visibility PostVisibility @default(FAMILY_ONLY)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  authorId String
  author   User    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  comments Comment[]
  likes    Like[]

  @@map("posts")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  postId   String
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Like {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("likes")
}

model ArchiveItem {
  id          String           @id @default(cuid())
  title       String
  description String?
  url         String
  images      String[] @default([])
  category    ArchiveCategory
  year        Int?
  tags        String[]
  createdAt   DateTime         @default(now())

  uploadedById String
  uploadedBy   User             @relation(fields: [uploadedById], references: [id])

  @@index([uploadedById])
  @@map("archive_items")
}

model FamilyMember {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  middleName  String?
  dateOfBirth DateTime?
  dateOfDeath DateTime?
  photo       String?
  bio         String?
  birthplace  String?
  location    String?
  latitude    Float?
  longitude   Float?
  createdAt   DateTime @default(now())

  familyId String?
  family   Family? @relation(fields: [familyId], references: [id])

  parentId    String?
  parent      FamilyMember?  @relation("FamilyRelation", fields: [parentId], references: [id])
  children    FamilyMember[] @relation("FamilyRelation")

  @@map("family_members")
}

model Message {
  id        String   @id @default(cuid())
  content   String
  image     String?
  file      String?
  createdAt DateTime @default(now())

  senderId   String
  sender     User   @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String?
  receiver   User?  @relation("ChatMessages", fields: [receiverId], references: [id])
  chatRoomId String?
  chatRoom   ChatRoom? @relation(fields: [chatRoomId], references: [id])

  @@index([senderId, receiverId])
  @@map("messages")
}

model ChatRoom {
  id        String   @id @default(cuid())
  name      String?
  createdAt DateTime @default(now())

  members  ChatRoomMember[]
  messages Message[]

  @@map("chat_rooms")
}

model ChatRoomMember {
  id       String   @id @default(cuid())
  joinedAt DateTime @default(now())

  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roomId String
  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
  @@map("chat_room_members")
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  date        DateTime
  type        EventType @default(CUSTOM)
  remindAt    DateTime?
  createdAt   DateTime  @default(now())

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  @@index([createdById])
  @@map("events")
}

model Memory {
  id        String   @id @default(cuid())
  title     String
  content   String
  image     String?
  audioUrl  String?
  year      Int?
  createdAt DateTime @default(now())

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@index([authorId])
  @@map("memories")
}

model Poll {
  id        String     @id @default(cuid())
  question  String
  options   String[]
  status    PollStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  endsAt    DateTime?

  authorId String
  author   User     @relation(fields: [authorId], references: [id])
  votes    PollVote[]

  @@map("polls")
}

model PollVote {
  id        String   @id @default(cuid())
  option    String
  createdAt DateTime @default(now())

  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@map("poll_votes")
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  details   String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

model Pet {
  id         String   @id @default(cuid())
  name       String
  species    String
  breed      String?
  dateOfBirth DateTime?
  photo      String?
  notes      String?
  createdAt  DateTime @default(now())

  photos    PetPhoto[]
  ownerId   String
  owner     User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  familyId  String

  @@index([familyId])
  @@map("pets")
}

model PetPhoto {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  createdAt DateTime @default(now())

  petId String
  pet   Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@map("pet_photos")
}
